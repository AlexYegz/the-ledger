# Required
CLAUDE_API_KEY=sk-ant-...
SESSION_SECRET=replace-with-32+-random-chars

# Optional (defaults shown)
LEDGER_PRINCIPAL_PASSWORD=principal
LEDGER_TEAM_PASSWORD=team

# Meeting Tracker handoff
MEETING_TRACKER_URL=https://meeting-tracker-production.up.railway.app
LEDGER_TO_TRACKER_TOKEN=shared-secret-between-the-two-apps

# Internal email domains (comma-separated)
INTERNAL_DOMAINS=alpha.school,trilogy.com

# Set by Railway automatically; safe to leave blank locally
PORT=5000
NODE_ENV=production
